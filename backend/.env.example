# ==============================
#  Voxyra Mail — Backend .env
# ==============================
# Copie para /app/backend/.env e ajuste os valores.

# MongoDB (obrigatório)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="voxyra_mail"

# CORS (frontend URL, ou "*" para desenvolvimento)
CORS_ORIGINS="*"

# JWT — gere com: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET="troque-por-uma-string-hex-de-64-caracteres"

# Superadmin inicial (semeado no primeiro startup)
ADMIN_EMAIL="admin@voxyra.com"
ADMIN_PASSWORD="Voxyra@2026"

# Chave para criptografar tokens DirectAdmin / senhas IMAP no banco
ENCRYPTION_KEY="troque-por-uma-string-de-32-caracteres"
